# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local to version control

# =====================================
# REQUIRED FOR BASIC FUNCTIONALITY
# =====================================

# Supabase Configuration (Required for auth and database)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Application URL (for email links and CORS)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# =====================================
# OPTIONAL SERVICES
# =====================================

# Sanity CMS (for property content management)
# You can skip this initially and use sample data
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2023-05-03
SANITY_API_TOKEN=your_sanity_token

# Email Service (SendGrid)
# Leave blank to run in development mode (emails will be logged to console)
SENDGRID_API_KEY=your_sendgrid_api_key

# Google Gemini AI (for AI-powered email content generation)
# Optional - falls back to static templates if not configured
# Get your free API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# OpenAI (for content generation - DEPRECATED, use Gemini instead)
# Optional - used for generating property descriptions
OPENAI_API_KEY=your_openai_api_key

# Stripe Payments (Premium PDFs)
# Keep disabled for initial launch unless you explicitly want the premium PDF flow live.
NEXT_PUBLIC_PREMIUM_PDFS_ENABLED=false
# Keep admin AI/upload tools disabled for the initial public launch unless explicitly needed.
ADMIN_LAUNCH_TOOLS_ENABLED=false
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PRICE_PREMIUM_NOTARY=price_xxxxxxxxxxxxx
STRIPE_PRICE_PREMIUM_DOMY=price_xxxxxxxxxxxxx
# Optional: enable Stripe automatic tax calculation where configured and legally validated
STRIPE_AUTOMATIC_TAX=false

# Premium PDF private storage (Supabase Storage)
PREMIUM_PDF_BUCKET=documents
PREMIUM_PDF_PATH_NOTARY=premium/premium-notary.pdf
PREMIUM_PDF_PATH_DOMY=premium/premium-domy.pdf

# Hash salts for compliance proofs (do not change frequently in production)
CONSENT_HASH_SALT=replace_with_random_long_secret
LEGAL_HASH_SALT=replace_with_random_long_secret

# MongoDB (Legacy - not actively used)
MONGODB_URI=mongodb://localhost:27017/italian-properties

# CORS Origins (for production)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# Cron jobs (alerts/follow-up automations)
# If set, cron endpoints require Authorization: Bearer <CRON_SECRET>
CRON_SECRET=replace_with_random_long_secret
# Comma-separated day milestones for follow-up emails after signup
FOLLOW_UP_DAYS=3

# =====================================
# DEVELOPMENT SETTINGS
# =====================================

# Node Environment
NODE_ENV=development

# Enable detailed logging
DEBUG=true
